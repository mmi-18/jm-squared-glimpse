// glimpse. — full schema (BetterAuth + domain).
// One Postgres, two concerns: auth tables (User/Session/Account/Verification)
// are managed by BetterAuth; the rest are glimpse domain tables.
//
// Conventions:
// - PascalCase model names + camelCase field names. No @map/@@map; the DB
//   gets quoted identifiers in the same case. This is Prisma-idiomatic.
// - All ids are cuid(). The old Supabase UUIDs are gone; this is a fresh DB.
// - timestamptz everywhere (timestamps survive timezone changes).
// - JSONB for cell_layout / preview_layout / portfolio_layout / about_layout
//   / social_handles. Typed as Json on the TS side.
// - No CHECK constraints / triggers / RLS — those move to the app layer
//   (server actions enforce ownership; auth happens via BetterAuth session).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ════════════════════════════════════════════════════════════════════════════
// ENUMS
// ════════════════════════════════════════════════════════════════════════════

enum UserType {
  creator
  startup
}

enum MembershipTier {
  free
  pro
}

enum Discipline {
  video
  photo
  both
}

enum CreativeDiscipline {
  videographer
  photographer
  both
  motion_designer
}

enum Availability {
  immediately
  within_1_week
  within_1_month
  limited
}

enum Turnaround {
  days_1_3 @map("1_3_days")
  week_1   @map("1_week")
  weeks_2  @map("2_weeks")
  month_1  @map("1_month")
  flexible
}

enum Travel {
  local_only
  regional
  national
  international
  worldwide
}

enum Licensing {
  full_buyout
  limited_usage
  negotiable
}

enum CompanyStage {
  pre_seed
  seed
  series_a
  series_b_plus
  established
}

enum BrandGuidelines {
  strict_brand_guide
  loose_guidelines
  no_guidelines
  open_to_suggestions
}

enum UsageRights {
  full_buyout
  limited_platform
  time_limited
  negotiable
}

enum TimelinePattern {
  urgent_1_week
  standard_2_4_weeks
  flexible
  ongoing
}

enum PostType {
  portfolio_piece
  job_listing
}

enum Format {
  vertical
  horizontal
  square
}

// State machine for the post-match working relationship between a startup
// (client) and a creator. See models/Project below + the Chunk A notes
// in CLAUDE.md.
//
//   pending    →  client + creator have a Project record, but work hasn't
//                 actively started (e.g. work agreement still being drafted)
//   active     →  agreed; creator is working
//   delivered  →  creator has uploaded final deliverable, client to review
//   completed  →  client has signed off; payout fires from this point
//   cancelled  →  either party cancelled before completion
//
// Transitions are enforced in the app layer (server actions), not at the
// DB level — Prisma can't express state machines natively.
enum ProjectStatus {
  pending
  active
  delivered
  completed
  cancelled
}

// Direction of a review on a Project. Two-way blind reviews — both sides
// rate each other after sign-off; neither sees the other's rating until
// both have submitted (or 14 days pass — see Chunk A4 cron).
enum ReviewDirection {
  client_to_creator
  creator_to_client
}

// ════════════════════════════════════════════════════════════════════════════
// AUTH (BetterAuth-managed)
// ════════════════════════════════════════════════════════════════════════════
//
// BetterAuth's Prisma adapter writes/reads these four tables. We extend
// `User` with glimpse domain fields so we don't need a parallel
// `users` / `auth.users` split like Supabase had.

model User {
  // ── BetterAuth core fields ────────────────────────────────────────────────
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  // ── Glimpse domain fields (formerly public.users in Supabase) ─────────────
  userType            UserType
  bio                 String?
  locationCity        String?
  locationCountry     String?
  languages           String[]       @default([])
  culturalMarkets     String[]       @default([])
  onboardingCompleted Boolean        @default(false)
  membershipTier      MembershipTier @default(free)

  // ── Relations ─────────────────────────────────────────────────────────────
  sessions          Session[]
  accounts          Account[]
  creatorProfile    CreatorProfile?
  startupProfile    StartupProfile?
  posts             Post[]
  briefs            Brief[]
  reviewsGiven      Review[]        @relation("Reviewer")
  reviewsReceived   Review[]        @relation("Reviewed")
  conversationsAsA  Conversation[]  @relation("ParticipantA")
  conversationsAsB  Conversation[]  @relation("ParticipantB")
  messagesSent      Message[]       @relation("Sender")
  messagesReceived  Message[]       @relation("Receiver")
  projectsAsClient  Project[]       @relation("Client")
  projectsAsCreator Project[]       @relation("Creator")

  @@index([userType])
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime @db.Timestamptz
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz
  refreshTokenExpiresAt DateTime? @db.Timestamptz
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz
  updatedAt             DateTime  @updatedAt @db.Timestamptz
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  @@index([identifier])
}

// ════════════════════════════════════════════════════════════════════════════
// CREATOR PROFILES
// ════════════════════════════════════════════════════════════════════════════

model CreatorProfile {
  userId String @id

  // Core
  discipline        Discipline?
  contentCategories String[]      @default([])
  contentStyleTags  String[]      @default([])
  deliverableTypes  String[]      @default([])
  rateMin           Int?
  rateMax           Int?
  availability      Availability?
  portfolioUrls     String[]      @default([])

  // Important
  subSpecializations       String[]            @default([])
  industryExperience       String[]            @default([])
  minimumAcceptableBudget  Int?
  typicalTurnaround        Turnaround?
  travelWillingness        Travel?
  preferredProjectTypes    String[]            @default([])
  unwantedWorkTypes        String[]            @default([])
  usageLicensingPreference Licensing?
  productionCapabilities   String[]            @default([])
  socialHandles            Json                @default("{}")
  creativeDiscipline       CreativeDiscipline?

  // Later
  equipment               String[] @default([])
  audienceSize            Int?
  pastBrandCollaborations String?
  creativePhilosophy      String?
  inspirationCreators     String[] @default([])
  showreelUrl             String?

  // Style (1–10) — range enforced in app layer
  styleProductionValue Int?
  stylePacing          Int?
  styleFocus           Int?
  styleFraming         Int?
  styleStaging         Int?
  styleColor           Int?
  styleSound           Int?

  // Derived / cached (recomputed by reviews logic)
  avgRating   Decimal? @db.Decimal(3, 2)
  reviewCount Int      @default(0)

  // User-arranged grid layouts (GridCell<PostCellData>[])
  portfolioLayout Json?
  aboutLayout     Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ════════════════════════════════════════════════════════════════════════════
// STARTUP PROFILES
// ════════════════════════════════════════════════════════════════════════════

model StartupProfile {
  userId String @id

  // Core
  companyName           String?
  industry              String?
  locationMarket        String[]  @default([])
  contactPerson         String?
  contactRole           String?
  contactEmail          String?
  typicalBudgetRangeMin Int?
  typicalBudgetRangeMax Int?
  projectGoal           String[]  @default([])
  desiredLookFeeling    String[]  @default([])
  deliverablesNeeded    String[]  @default([])
  quantityVolume        Int?
  deadline              DateTime? @db.Date
  budgetForProject      Int?
  contentUsagePlatforms String[]  @default([])

  // Important
  companyStage                  CompanyStage?
  websiteUrl                    String?
  companyDescription            String?
  contentCategoriesHired        String[]         @default([])
  brandLookGuidelines           BrandGuidelines?
  language                      String[]         @default([])
  targetAudience                String[]         @default([])
  qualitiesInCreator            String[]         @default([])
  contentCommunicationGoal      String[]         @default([])
  successCriteria               String?
  usageRightsScope              UsageRights?
  locationProductionConstraints String[]         @default([])
  equipmentNeeded               String[]         @default([])

  // Later
  brandValues               String[]         @default([])
  pastCreatorCollaborations String?
  typicalTimelinePattern    TimelinePattern?
  brandGuidelinesUrl        String?
  referenceContentUrls      String[]         @default([])
  brandDescription          String?

  // Style (1–10)
  styleProductionValue Int?
  stylePacing          Int?
  styleFocus           Int?
  styleFraming         Int?
  styleStaging         Int?
  styleColor           Int?
  styleSound           Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ════════════════════════════════════════════════════════════════════════════
// POSTS
// ════════════════════════════════════════════════════════════════════════════

model Post {
  id           String   @id @default(cuid())
  userId       String
  postType     PostType
  title        String?
  description  String?
  mediaUrls    String[] @default([])
  thumbnailUrl String?

  contentType     String?
  industry        String?
  format          Format?
  durationSeconds Int?
  equipmentUsed   String[] @default([])

  styleProductionValue Int?
  stylePacing          Int?
  styleFocus           Int?
  styleFraming         Int?
  styleStaging         Int?
  styleColor           Int?
  styleSound           Int?

  likesCount Int      @default(0)
  viewsCount Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz

  // User-arranged grid layouts
  cellLayout    Json?
  previewLayout Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postType])
  @@index([createdAt(sort: Desc)])
}

// ════════════════════════════════════════════════════════════════════════════
// CONVERSATIONS & MESSAGES
// ════════════════════════════════════════════════════════════════════════════

model Conversation {
  id            String    @id @default(cuid())
  participantA  String
  participantB  String
  matchScore    Float?
  lastMessageAt DateTime? @db.Timestamptz
  createdAt     DateTime  @default(now()) @db.Timestamptz

  userA    User      @relation("ParticipantA", fields: [participantA], references: [id], onDelete: Cascade)
  userB    User      @relation("ParticipantB", fields: [participantB], references: [id], onDelete: Cascade)
  messages Message[]
  projects Project[]

  @@unique([participantA, participantB])
  @@index([participantA])
  @@index([participantB])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String?
  senderId       String
  receiverId     String
  content        String
  // Attachment URLs — bucket links from /api/upload (Hetzner Object
  // Storage). Empty array if text-only. Order matters; rendered in
  // the conversation as a grid below the text bubble.
  attachmentUrls String[] @default([])
  read           Boolean  @default(false)
  matchScore     Float?
  createdAt      DateTime @default(now()) @db.Timestamptz

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User          @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User          @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([receiverId, read])
}

// ════════════════════════════════════════════════════════════════════════════
// REVIEWS
// ════════════════════════════════════════════════════════════════════════════

model Review {
  id                  String           @id @default(cuid())
  reviewerId          String
  reviewedId          String
  // Project the review is for. Nullable so reviews seeded before
  // projects existed (the migrated Supabase set) keep working.
  projectId           String?
  // Which way this review goes. Nullable for the legacy seed reviews
  // that pre-date the project flow.
  direction           ReviewDirection?
  // Two-way blind: a review is invisible to the other party (and on
  // public profiles) until BOTH directions on the same project have
  // been submitted, or the 14-day stale-release cron fires.
  // Default true preserves visibility of pre-existing seed reviews.
  released            Boolean          @default(true)

  projectDescription  String?
  ratingOverall       Int? // 1-5, enforced in app
  ratingReliability   Int?
  ratingQuality       Int?
  ratingCollaboration Int?
  reviewText          String?
  createdAt           DateTime         @default(now()) @db.Timestamptz

  reviewer User     @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewed User     @relation("Reviewed", fields: [reviewedId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([reviewedId])
  @@index([projectId])
  // (We'd love a @@unique([projectId, reviewerId]) but Prisma's migrate
  //  flow blocks the constraint addition non-interactively when warning
  //  about possible duplicates. The submitReview action already checks
  //  for existing rows before inserting, so the constraint is belt-and-
  //  suspenders rather than essential. Add later if seed data permits.)
}

// ════════════════════════════════════════════════════════════════════════════
// BRIEFS (Pro-only, created by startups)
// ════════════════════════════════════════════════════════════════════════════

model Brief {
  id                 String   @id @default(cuid())
  userId             String
  title              String
  description        String
  referenceImageUrls String[] @default([])
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

// ════════════════════════════════════════════════════════════════════════════
// PROJECTS (the post-match working relationship between a startup and a
// creator). Sign-off, deliverables, reviews, and eventually escrow all
// hang off this row. See CLAUDE.md "Commercial model" for the fee
// structure (10% client / 5% creator) that gets applied at completion.
// ════════════════════════════════════════════════════════════════════════════

model Project {
  id             String  @id @default(cuid())
  // Two parties. Enforced in app code: client.userType must be `startup`,
  // creator.userType must be `creator`. Prisma can't express that.
  clientId       String
  creatorId      String
  // Optional pointer back to the conversation that led to this project.
  // Nullable: a project might be created from a brief response or
  // back-channel without a prior DM.
  conversationId String?

  title  String
  status ProjectStatus @default(pending)

  // ─── Work agreement (Chunk C) ────────────────────────────────────────────
  // The structured deal both parties accept before status flips
  // pending → active. All nullable so legacy / dev-created projects
  // (pre-Chunk C) keep working. The Hire flow (`/creator/<id>` →
  // "Hire" button) populates these on creation; either party can
  // amend, which clears the *other* party's acceptance and forces
  // re-acceptance.
  scope          String?
  deliverables   String?
  // Face value of the project in cents of `currency`. €5,000 = 500000.
  // Stored in cents to dodge floating-point rounding (the same reason
  // Stripe / Mollie / Adyen all do this).
  priceCents     Int?
  currency       String      @default("EUR")
  // When the creator's deliverable is due. Date-only (no clock —
  // calendar deadlines are how creators think).
  deadline       DateTime?   @db.Date
  // How many revision passes are baked into the price.
  revisionRounds Int?
  // What the client may do with the finished work — rights bundle.
  // Reuses the same enum as the StartupProfile preference field.
  usageRights    UsageRights?

  // Per-party acceptance timestamps. Both non-null AND `paidAt` set
  // → server action flips to status=active. (Pre-Chunk-F-prep this
  // flipped on both-accept alone; now the deposit gate sits between.)
  // An amendment clears the *non-amending* party's acceptance.
  clientAcceptedAt  DateTime? @db.Timestamptz
  creatorAcceptedAt DateTime? @db.Timestamptz

  // ─── Deposit / payout (Chunk F-prep) ──────────────────────────────────────
  // Money flow lives on the same Project row so we don't need a
  // separate Payment table while everything is single-currency,
  // single-creator, single-deposit. When team-ups (docs/IDEAS.md)
  // arrive, this needs to migrate to a per-member ProjectMember
  // join with its own payment fields.
  //
  // `paidAt` — set by `markProjectPaid` when the client confirms
  //   the deposit. Both-accepted + paidAt=null = "Deposit €X to
  //   start" CTA. Both-accepted + paidAt!=null flips status →
  //   active. NB: this is a placeholder timestamp — Chunk F-stripe
  //   will replace the action with a real Stripe Checkout session
  //   and have the webhook set this column.
  paidAt                  DateTime? @db.Timestamptz
  // `stripeCheckoutSessionId` — null today; populated when Chunk
  //   F-stripe lands. Lets us reconcile deposits against Stripe's
  //   dashboard and dedupe webhook deliveries.
  stripeCheckoutSessionId String?
  // `payoutScheduledFor` — set when client signs off, equal to
  //   `signedOffAt + 24h`. The 24-hour undo window protects this:
  //   if `undoSignOff` fires within 24h, this clears too. The
  //   daily cron releases payouts where this is past + still null
  //   in `payoutReleasedAt`.
  payoutScheduledFor      DateTime? @db.Timestamptz
  // `payoutReleasedAt` — set by the daily cron when it processes
  //   the release. Today this is just a flag; Chunk F-stripe
  //   replaces it with `stripe.transfers.create(...)`.
  payoutReleasedAt        DateTime? @db.Timestamptz

  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  // Set when status transitions to `completed`. Nullable until then.
  signedOffAt DateTime? @db.Timestamptz
  // Set when status transitions to `cancelled`.
  cancelledAt DateTime? @db.Timestamptz

  client       User          @relation("Client", fields: [clientId], references: [id], onDelete: Cascade)
  creator      User          @relation("Creator", fields: [creatorId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  reviews      Review[]

  @@index([clientId])
  @@index([creatorId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

// ════════════════════════════════════════════════════════════════════════════
// INDUSTRY SIMILARITY (matchmaking lookup table — seeded, not user-edited)
// ════════════════════════════════════════════════════════════════════════════

model IndustrySimilarity {
  industryA       String
  industryB       String
  similarityScore Float

  @@id([industryA, industryB])
}
