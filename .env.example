# Copy this to .env and fill in real values. Never commit .env.

# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Pooled connection string (host contains "-pooler"). Used at runtime by
# Prisma Client and the rest of the app.
DATABASE_URL="postgresql://neondb_owner:<password>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Direct connection string (no "-pooler" in host). Used by Prisma Migrate
# for DDL operations — pgbouncer can't run those reliably.
DIRECT_URL="postgresql://neondb_owner:<password>@<host>.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── BetterAuth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="<32-byte base64 secret>"

# Where the app is served from. Local dev: http://localhost:3000.
# Production: https://glimpse.jm-squared.com.
BETTER_AUTH_URL="http://localhost:3000"

# ─── Public site URL ──────────────────────────────────────────────────────────
# Used by getSiteUrl() / absoluteUrl() for metadata, og:image, robots.txt,
# sitemap.xml. Should match BETTER_AUTH_URL in most cases.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
