# Copy this to .env and fill in real values. Never commit .env.

# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Pooled connection string (host contains "-pooler"). Used at runtime by
# Prisma Client and the rest of the app.
DATABASE_URL="postgresql://neondb_owner:<password>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Direct connection string (no "-pooler" in host). Used by Prisma Migrate
# for DDL operations — pgbouncer can't run those reliably.
DIRECT_URL="postgresql://neondb_owner:<password>@<host>.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── BetterAuth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="<32-byte base64 secret>"

# Where the app is served from. Local dev: http://localhost:3000.
# Production: https://glimpse.jm-squared.com.
BETTER_AUTH_URL="http://localhost:3000"

# ─── Public site URL ──────────────────────────────────────────────────────────
# Used by getSiteUrl() / absoluteUrl() for metadata, og:image, robots.txt,
# sitemap.xml. Should match BETTER_AUTH_URL in most cases.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Cron secret ──────────────────────────────────────────────────────────────
# Shared secret used by /api/cron/release-stale-reviews. The GitHub Actions
# workflow .github/workflows/cron-release-reviews.yml POSTs to that endpoint
# with `Authorization: Bearer <CRON_SECRET>` once a day; this value must
# match between the server's .env and the GitHub repo's Actions secrets.
# Generate with: openssl rand -base64 32
CRON_SECRET="<32-byte base64 secret>"

# ─── Hetzner Object Storage ──────────────────────────────────────────────────
# S3-compatible bucket used for user uploads (post images, future delivery
# files, avatars). Bucket lives in NBG1 — same datacenter as the server, so
# uploads + downloads between container and bucket are free internal traffic.
# Generate the access keys in Hetzner Console → Security → S3 credentials.
HETZNER_S3_ENDPOINT="https://nbg1.your-objectstorage.com"
HETZNER_S3_BUCKET="<bucket-name>"
HETZNER_S3_REGION="nbg1"
HETZNER_S3_ACCESS_KEY="<20-char access key id>"
HETZNER_S3_SECRET_KEY="<40-char secret>"
# Path-style URL the browser fetches uploaded objects from. Same endpoint
# + bucket name; broken out so render code doesn't have to concatenate.
HETZNER_S3_PUBLIC_URL="https://nbg1.your-objectstorage.com/<bucket-name>"
